# Single source of truth for pinned versions.
# Sourced by every script and CI stage so the add-on path and the helm-fallback
# path always install byte-identical software.

# Flyte 2 backend chart (flyte-binary line) from https://helm.flyte.org
FLYTE_CHART_REPO="https://helm.flyte.org"
FLYTE_CHART_NAME="flyte-binary"
FLYTE_CHART_VERSION="v2.0.27"

# Name/version this repo publishes the EKS add-on under. Bump ADDON_VERSION on
# any change to the chart, values template, or config schema. The deploy
# resolver treats "add-on version present in the catalog" as the signal to use
# the AWS::EKS::Addon path; otherwise it falls back to a direct helm install of
# the same pinned chart.
ADDON_NAMESPACE="flyte"
ADDON_PRODUCT_NAME="union_flyte-eks"      # marketplace product slug (placeholder)
ADDON_VERSION="v0.1.0"

# Kubernetes / tooling floor
EKS_K8S_VERSION="1.31"
HELM_MIN_VERSION="3.14.0"
